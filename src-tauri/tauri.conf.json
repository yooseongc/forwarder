{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri-docs/master/tauri.conf.json.schema.json",
  "productName": "SSH Forwarder",
  "version": "1.0.0",
  "identifier": "com.forwarder.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "SSH Forwarder",
        "width": 960,
        "height": 640,
        "minWidth": 760,
        "minHeight": 500,
        "decorations": true,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
